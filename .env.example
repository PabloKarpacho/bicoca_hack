ENV=local
DEBUG=false

# App ports and container names
APP_PORT=8000
FRONTEND_PORT=9001
BACKEND_CONTAINER_NAME=backend_api_local
FRONTEND_CONTAINER_NAME=frontend_ui_local

# FastAPI docs
DOCS_URL=/docs
REDOC_URL=/redoc

# PostgreSQL
DB_POSTGRES_HOST=localhost
DB_POSTGRES_CONTAINER_NAME=backend_db_postgres_local
DB_POSTGRES_USERNAME=backend_username
DB_POSTGRES_PASSWORD=CHANGE_ME
DB_POSTGRES_NAME=backend_db
DB_POSTGRES_PORT=32735
DB_POSTGRES_URL_ASYNC=postgresql+asyncpg://backend_username:CHANGE_ME@localhost:32735/backend_db
DB_POSTGRES_URL_SYNC=postgresql://backend_username:CHANGE_ME@localhost:32735/backend_db
DOCKER_DB_POSTGRES_URL_ASYNC=postgresql+asyncpg://backend_username:CHANGE_ME@postgres:5432/backend_db
DOCKER_DB_POSTGRES_URL_SYNC=postgresql://backend_username:CHANGE_ME@postgres:5432/backend_db

# pgAdmin
PGADMIN_CONTAINER_NAME=backend_pgadmin_local
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME
PGADMIN_PORT=5050

# MinIO / S3
S3_ROOT_USER=admin
S3_ROOT_PASSWORD=CHANGE_ME
S3_FILES_BUCKET_NAME=files
S3_ENDPOINT=http://localhost:9000
DOCKER_S3_ENDPOINT=http://minio:9000
S3_REGION_NAME=us-east-1
S3_CONTAINER_NAME=backend_s3_local
S3_API_PORT=9000
S3_CONSOLE_PORT=7001

# Qdrant
QDRANT_CONTAINER_NAME=backend_qdrant_local
QDRANT_HOST=0.0.0.0
QDRANT_PORT=6333
QDRANT_URL=http://localhost:6333
DOCKER_QDRANT_URL=http://qdrant:6333
QDRANT_CANDIDATE_CHUNKS_COLLECTION_NAME=candidate_chunks

# CORS
ORIGINS=["*"]

# LLM and embeddings
LLM_API_KEY=CHANGE_ME
LLM_BASE_URL=https://api.openai.com/v1
LLM_CV_EXTRACTION_MODEL_NAME=gpt-5.4-nano
LLM_JOB_SEARCH_PREPARATION_MODEL_NAME=gpt-5.4-nano
LLM_ENTITY_NORMALIZATION_MODEL_NAME=gpt-5.4-nano
LLM_DOC_SUMMARY_MODEL_NAME=gpt-5.4-nano
EMBEDDING_MODEL_NAME=text-embedding-3-small

# Unstructured
UNSTRUCTURED_API_KEY=CHANGE_ME

# HH autosuggest
HH_AUTOSUGGEST_BASE_URL=https://hh.ru
HH_AUTOSUGGEST_TIMEOUT_SECONDS=5
HH_AUTOSUGGEST_ENABLED=true
HH_AUTOSUGGEST_MAX_ITEMS_TO_CONSIDER=5
HH_AUTOSUGGEST_MIN_CONFIDENCE_THRESHOLD=0.55
HH_AUTOSUGGEST_USER_AGENT=hack-cv-service/1.0
HH_AUTOSUGGEST_CACHE_TTL_SECONDS=1800
